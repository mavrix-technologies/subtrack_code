{
  "buildCommand": "npm run build:website",
  "outputDirectory": "website",
  "cleanUrls": true,
  "functions": {
    "api/reminders/*.ts": {
      "maxDuration": 30,
      "memory": 1024
    },
    "api/assistant/*.ts": {
      "maxDuration": 30,
      "memory": 1024
    }
  },
  "rewrites": [
    {
      "source": "/reminders/:path*",
      "destination": "/api/reminders/:path*"
    },
    {
      "source": "/assistant/:path*",
      "destination": "/api/assistant/:path*"
    }
  ]
}
